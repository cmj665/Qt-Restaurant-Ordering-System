<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">


<mapper namespace="org.csu.restaurant.restaurantserver.mapper.TableMapper">

    <!-- 查询桌台 -->
    <select id="findAll"
            resultType="org.csu.restaurant.restaurantserver.entity.DiningTable">


        SELECT
        id,
        table_name,
        capacity,
        status

        FROM dining_table

    </select>


    <!-- 修改状态 -->
    <update id="updateStatus">


        UPDATE dining_table

        SET status=#{status}

        WHERE id=#{id}


    </update>

    <select id="findById"
            resultType="org.csu.restaurant.restaurantserver.entity.DiningTable">

        SELECT
            id,
            table_name AS tableName,
            capacity,
            status

        FROM dining_table

        WHERE id=#{id}

    </select>


</mapper>