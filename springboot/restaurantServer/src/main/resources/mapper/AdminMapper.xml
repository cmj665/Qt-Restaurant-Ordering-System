<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="org.csu.restaurant.restaurantserver.mapper.AdminMapper">

    <select id="findByUsername"
            resultType="org.csu.restaurant.restaurantserver.entity.Admin">

        SELECT

        id,
        username,
        password,
        role

        FROM admin

        WHERE username=#{username}

    </select>

</mapper>